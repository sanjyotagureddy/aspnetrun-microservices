    <PackageVersion Include="Npgsql" Version="7.0.7" />
    <PackageVersion Include="NUnit" Version="3.13.3" />
    <PackageVersion Include="NUnit3TestAdapter" Version="4.4.2" />
    <PackageVersion Include="Ocelot" Version="18.0.0" />
    <PackageVersion Include="Ocelot.Cache.CacheManager" Version="18.0.0" />
