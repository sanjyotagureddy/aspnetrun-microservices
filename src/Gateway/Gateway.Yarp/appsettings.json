{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "products-route": {
        "ClusterId": "products-cluster",
        "RateLimiterPolicy": "public-read",
        "Match": {
          "Path": "/api/v1/products/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "RateLimiterPolicy": "public-read",
        "Match": {
          "Path": "/api/v1/inventory/{**catch-all}"
        }
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "AuthorizationPolicy": "GatewayApiKeyPolicy",
        "RateLimiterPolicy": "protected-write",
        "Match": {
          "Path": "/api/v1/cart/{**catch-all}"
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "GatewayApiKeyPolicy",
        "RateLimiterPolicy": "protected-write",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "products-cluster": {
        "Destinations": {
          "products-api": {
            "Address": "http://products-api"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory-api": {
            "Address": "http://inventory-api"
          }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "cart-api": {
            "Address": "http://cart-api"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-api": {
            "Address": "http://order-api"
          }
        }
      }
    }
  },
  "GatewaySecurity": {
    "ApiKey": "change-this-in-user-secrets-or-env"
  },
  "AllowedHosts": "*"
}
