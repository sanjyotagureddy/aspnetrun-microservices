{
  "Auth": {
    "Authority": "http://localhost:8080/realms/commerce",
    "Issuer": "http://localhost:8080/realms/commerce",
    "Audience": "gateway-yarp"
  },
  "ReverseProxy": {
    "Routes": {
      "products-read": {
        "ClusterId": "products-cluster",
        "AuthorizationPolicy": "GatewayProductsReadPolicy",
        "Match": {
          "Path": "/api/v1/products/{**catch-all}",
          "Methods": [ "GET", "HEAD" ]
        }
      },
      "products-write": {
        "ClusterId": "products-cluster",
        "AuthorizationPolicy": "GatewayProductsWritePolicy",
        "Match": {
          "Path": "/api/v1/products/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        }
      }
    },
    "Clusters": {
      "products-cluster": {
        "Destinations": {
          "products-api": {
            "Address": "https+http://products-api/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
