{
  "Logging": {
    "CommonSharedKernel": {
      "ServiceName": "inventory-api",
      "MinimumLevel": "Trace",
      "EnabledLogTypes": [
        "api",
        "trace",
        "event"
      ],
      "Console": {
        "FormatterKind": "Json"
      },
      "OpenSearch": {
        "Enabled": false,
        "Endpoint": "http://localhost:9200",
        "ApiIndexPrefix": "api-logs",
        "InfraIndexPrefix": "infra-logs",
        "MessagingIndexPrefix": "messaging-log",
        "UseDailyIndexes": true
      }
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
