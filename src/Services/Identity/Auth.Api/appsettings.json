{
  "Auth": {
    "Authority": "http://localhost:8080/realms/commerce",
    "Issuer": "http://localhost:8080/realms/commerce",
    "DiscoveryUrl": "http://localhost:8080/realms/commerce/.well-known/openid-configuration",
    "JwksUrl": "http://localhost:8080/realms/commerce/protocol/openid-connect/certs",
    "Audience": "auth-api",
    "WebClientId": "web-app",
    "WebClientScope": "openid profile email",
    "PkceClients": [
      {
        "ClientId": "web-app",
        "Scope": "openid profile email",
        "RedirectUris": [
          "http://localhost:5173/auth/callback"
        ]
      }
    ]
  },
  "WorkloadAuth": {
    "Clients": [
      {
        "ClientId": "gateway-yarp",
        "AllowedScopes": [
          "gateway.proxy"
        ]
      },
      {
        "ClientId": "products-api",
        "AllowedScopes": [
          "products.read",
          "products.write"
        ]
      },
      {
        "ClientId": "inventory-api",
        "AllowedScopes": [
          "inventory.read",
          "inventory.write"
        ]
      },
      {
        "ClientId": "order-api",
        "AllowedScopes": [
          "orders.read",
          "orders.write"
        ]
      },
      {
        "ClientId": "cart-api",
        "AllowedScopes": [
          "cart.read",
          "cart.write"
        ]
      }
    ]
  },
  "ServiceCredentials": {
    "RotationDays": 30,
    "ExpiryDays": 90,
    "RevocationPropagationSeconds": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
