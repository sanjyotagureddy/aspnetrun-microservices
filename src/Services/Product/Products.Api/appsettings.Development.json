{
  "Logging": {
    "CommonSharedKernel": {
      "ServiceName": "Products.Api",
      "MinimumLevel": "Trace",
      "Console": {
        "FormatterKind": "Json"
      },
      "OpenSearch": {
        "Enabled": false,
        "Endpoint": "http://localhost:9200",
        "ApiIndexPrefix": "api-logs",
        "InfraIndexPrefix": "infra-logs",
        "UseDailyIndexes": true
      }
    },
    "Policy": {
      "EnableRedaction": true,
      "RedactExceptionMessages": true,
      "SensitiveKeys": [
        "supplierCost",
        "internalNotes",
        "buyerEmail"
      ]
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Services": {
    "Inventory": {
      "BaseUrl": "https+http://inventory-api"
    }
  }
}
