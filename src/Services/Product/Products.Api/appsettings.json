{
  "Logging": {
    "_commentRedactionMasking": "Logging.Policy protects top-level log fields; Logging.PayloadProtection protects nested payload bodies.",
    "CommonSharedKernel": {
      "ServiceName": "products-api",
      "MinimumLevel": "Trace",
      "EnabledLogTypes": [
        "api",
        "trace",
        "error"
      ],
      "Console": {
        "FormatterKind": "Json"
      },
      "OpenSearch": {
        "Enabled": false,
        "Endpoint": "http://localhost:9200",
        "AppIndexPrefix": "app-log",
        "MessagingIndexPrefix": "messaging-log",
        "AuditIndexPrefix": "audit-log",
        "SecurityIndexPrefix": "security-log",
        "PayloadIndexPrefix": "payload-log",
        "UseDailyIndexes": true
      }
    },
    "Policy": {
      "EnableRedaction": true,
      "RedactExceptionMessages": true,
      "SensitiveKeys": [
        "supplierCost",
        "internalNotes",
        "buyerEmail"
      ],
      "MaskingExcludedFields": [
        "productId"
      ]
    },
    "PayloadProtection": {
      "Enabled": true,
      "GlobalSensitiveFields": [],
      "MaskingExcludedFields": [
        "productId"
      ],
      "Rules": []
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Services": {
    "Inventory": {
      "BaseUrl": "https+http://inventory-api"
    }
  },
  "Messaging": {
    "OutboxHeartbeat": {
      "Enabled": false,
      "Interval": "00:05:00"
    }
  },
  "AllowedHosts": "*"
}




