{
  "Logging": {
    "_commentRedactionMasking": "Logging.Policy protects top-level log fields; Logging.PayloadProtection protects nested payload bodies.",
    "Policy": {
      "EnableRedaction": true,
      "RedactExceptionMessages": true,
      "SensitiveKeys": [],
      "MaskingExcludedFields": [
        "productId"
      ]
    },
    "PayloadProtection": {
      "Enabled": true,
      "GlobalSensitiveFields": [],
      "MaskingExcludedFields": [
        "productId"
      ],
      "Rules": []
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}




