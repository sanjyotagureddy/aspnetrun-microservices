{
  "info": {
    "_postman_id": "fcb5f7cf-04fa-4f37-8946-571598f89142",
    "name": "aspnetrun Auth Bootstrap and Token Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Bootstraps first admin user and tenant membership, then generates tokens and calls Auth API endpoints.\n\nFolders:\n- Admin\n- User\n- Tenant (Vendor)"
  },
  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "1. Get Keycloak Admin Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "admin-cli", "type": "text" },
                { "key": "username", "value": "{{keycloak_admin_username}}", "type": "text" },
                { "key": "password", "value": "{{keycloak_admin_password}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloak_base_url}}/realms/master/protocol/openid-connect/token",
              "host": ["{{keycloak_base_url}}"],
              "path": ["realms", "master", "protocol", "openid-connect", "token"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('admin_access_token', json.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Ensure Commerce Realm Exists",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"realm\": \"{{commerce_realm}}\",\n  \"enabled\": true\n}"
            },
            "url": {
              "raw": "{{keycloak_base_url}}/admin/realms",
              "host": ["{{keycloak_base_url}}"],
              "path": ["admin", "realms"]
            },
            "description": "Creates the realm if missing. Keycloak returns 201 when created, and 409 if it already exists."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Register User (Keycloak Admin API)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{new_user_username}}\",\n  \"email\": \"{{new_user_email}}\",\n  \"enabled\": true,\n  \"emailVerified\": true,\n  \"firstName\": \"{{new_user_first_name}}\",\n  \"lastName\": \"{{new_user_last_name}}\"\n}"
            },
            "url": {
              "raw": "{{keycloak_base_url}}/admin/realms/{{commerce_realm}}/users",
              "host": ["{{keycloak_base_url}}"],
              "path": ["admin", "realms", "{{commerce_realm}}", "users"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Resolve User Id by Username",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}" }
            ],
            "url": {
              "raw": "{{keycloak_base_url}}/admin/realms/{{commerce_realm}}/users?username={{new_user_username}}&exact=true",
              "host": ["{{keycloak_base_url}}"],
              "path": ["admin", "realms", "{{commerce_realm}}", "users"],
              "query": [
                { "key": "username", "value": "{{new_user_username}}" },
                { "key": "exact", "value": "true" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var arr = pm.response.json();",
                  "pm.test('User exists', function () { pm.expect(arr.length).to.be.greaterThan(0); });",
                  "pm.environment.set('keycloak_user_id', arr[0].id);",
                  "pm.environment.set('keycloak_user_sub', arr[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Set User Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"password\",\n  \"value\": \"{{new_user_password}}\",\n  \"temporary\": false\n}"
            },
            "url": {
              "raw": "{{keycloak_base_url}}/admin/realms/{{commerce_realm}}/users/{{keycloak_user_id}}/reset-password",
              "host": ["{{keycloak_base_url}}"],
              "path": ["admin", "realms", "{{commerce_realm}}", "users", "{{keycloak_user_id}}", "reset-password"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204', function () { pm.response.to.have.status(204); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tenant (Vendor)",
      "item": [
        {
          "name": "5. Bootstrap First Platform Admin Membership (Development Only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"{{keycloak_user_sub}}\",\n  \"tenantId\": \"{{vendor_tenant_id}}\",\n  \"role\": \"platform_admin\",\n  \"secret\": \"{{dev_bootstrap_secret}}\"\n}"
            },
            "url": {
              "raw": "{{auth_api_base_url}}/api/v1/auth/internal/bootstrap/memberships",
              "host": ["{{auth_api_base_url}}"],
              "path": ["api", "v1", "auth", "internal", "bootstrap", "memberships"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 200', function () { pm.expect([201,200]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "6. Generate Vendor Token (Token Endpoint)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "{{vendor_token_client_id}}", "type": "text" },
                { "key": "client_secret", "value": "{{vendor_token_client_secret}}", "type": "text" },
                { "key": "username", "value": "{{vendor_username}}", "type": "text" },
                { "key": "password", "value": "{{vendor_password}}", "type": "text" },
                { "key": "scope", "value": "openid profile email products.read products.write", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloak_base_url}}/realms/{{commerce_realm}}/protocol/openid-connect/token",
              "host": ["{{keycloak_base_url}}"],
              "path": ["realms", "{{commerce_realm}}", "protocol", "openid-connect", "token"]
            },
            "description": "Generates token for vendor user. Configure vendor token client in Keycloak."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('vendor_access_token', json.access_token);",
                  "pm.environment.set('vendor_refresh_token', json.refresh_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "7. Assign Tenant Role (Requires vendor platform_admin Token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendor_access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"{{target_user_sub}}\",\n  \"role\": \"{{target_tenant_role}}\",\n  \"audit\": {\n    \"reasonCode\": \"TENANT_BOOTSTRAP\",\n    \"changeTicketId\": \"CHG-LOCAL-001\",\n    \"approvedBy\": \"{{new_user_username}}\",\n    \"approvedAtUtc\": \"2026-06-13T00:00:00Z\"\n  }\n}"
            },
            "url": {
              "raw": "{{auth_api_base_url}}/api/v1/auth/internal/tenants/{{vendor_tenant_id}}/memberships",
              "host": ["{{auth_api_base_url}}"],
              "path": ["api", "v1", "auth", "internal", "tenants", "{{vendor_tenant_id}}", "memberships"]
            }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "7. Generate User Token (Token Endpoint)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "{{user_token_client_id}}", "type": "text" },
                { "key": "client_secret", "value": "{{user_token_client_secret}}", "type": "text" },
                { "key": "username", "value": "{{new_user_username}}", "type": "text" },
                { "key": "password", "value": "{{new_user_password}}", "type": "text" },
                { "key": "scope", "value": "openid profile email products.read products.write", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{keycloak_base_url}}/realms/{{commerce_realm}}/protocol/openid-connect/token",
              "host": ["{{keycloak_base_url}}"],
              "path": ["realms", "{{commerce_realm}}", "protocol", "openid-connect", "token"]
            },
            "description": "This uses ROPC for local development only. Configure a Keycloak client with direct access grants enabled."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('user_access_token', json.access_token);",
                  "pm.environment.set('user_refresh_token', json.refresh_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "8. Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_access_token}}" }
            ],
            "url": {
              "raw": "{{auth_api_base_url}}/api/v1/auth/me",
              "host": ["{{auth_api_base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        },
        {
          "name": "9. Logout Endpoint",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{user_access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": null,\n  \"refreshToken\": \"{{user_refresh_token}}\",\n  \"accessTokenJti\": null\n}"
            },
            "url": {
              "raw": "{{auth_api_base_url}}/api/v1/auth/logout",
              "host": ["{{auth_api_base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        }
      ]
    }
  ]
}
